{
  "manifest_version": 3,
  "name": "Pinpoint",
  "description": "AI 编程定位、网页样式编辑与批注工具",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "run_at": "document_idle"
    }
  ]
}